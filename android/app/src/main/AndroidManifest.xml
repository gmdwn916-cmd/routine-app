<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- 빠른 할일 추가 위젯 -->
        <receiver
            android:name=".QuickAddWidgetProvider"
            android:label="할 일 추가"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_add_info" />
        </receiver>

        <activity
            android:name=".QuickAddActivity"
            android:theme="@style/QuickAddDialogTheme"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:windowSoftInputMode="stateAlwaysVisible"
            android:exported="false" />

        <!-- 이번 달 달력 위젯(읽기 전용) -->
        <receiver
            android:name=".MonthCalendarWidgetProvider"
            android:label="달력"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_month_calendar_info" />
        </receiver>

        <!-- N주 스케줄 위젯(읽기 전용) -->
        <receiver
            android:name=".ScheduleWidgetProvider"
            android:label="스케줄"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_schedule_info" />
        </receiver>

        <!-- 오늘 전체 관리 위젯(체크 가능) -->
        <receiver
            android:name=".TodayWidgetProvider"
            android:label="오늘 할일"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_today_info" />
        </receiver>
        <service
            android:name=".TodayWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- 미배치 위젯(읽기 전용) -->
        <receiver
            android:name=".InboxWidgetProvider"
            android:label="미배치"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_inbox_info" />
        </receiver>
        <service
            android:name=".InboxWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 데이터 내보내기(saveBackupFile)에서 안드로이드 9 이하 기기일 때만 필요.
         안드로이드 10+에서는 MediaStore 방식이라 이 권한 자체가 필요 없음. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
</manifest>
