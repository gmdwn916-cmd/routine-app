<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- 빠른 할일 추가 위젯 -->
        <receiver
            android:name=".QuickAddWidgetProvider"
            android:label="할 일 추가"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 휴대폰 시스템 다크/라이트 설정이 바뀌는 순간 위젯을 새로
                     그리기 위함(2026-07-18 추가) — 앱을 안 열고 위젯만 떠있는
                     상태에서 시스템 테마가 바뀌면 이전까지는 앱을 열기 전까지
                     위젯이 예전 밝기 그대로 남아있었음(색이 안 맞아 리스트가
                     제대로 안 보이는 신고 원인). -->
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_add_info" />
        </receiver>

        <activity
            android:name=".QuickAddActivity"
            android:theme="@style/QuickAddDialogTheme"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:windowSoftInputMode="stateAlwaysVisible"
            android:exported="false" />

        <!-- 이번 달 달력 위젯(읽기 전용) -->
        <receiver
            android:name=".MonthCalendarWidgetProvider"
            android:label="달력"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 휴대폰 시스템 다크/라이트 설정이 바뀌는 순간 위젯을 새로
                     그리기 위함(2026-07-18 추가) — 앱을 안 열고 위젯만 떠있는
                     상태에서 시스템 테마가 바뀌면 이전까지는 앱을 열기 전까지
                     위젯이 예전 밝기 그대로 남아있었음(색이 안 맞아 리스트가
                     제대로 안 보이는 신고 원인). -->
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_month_calendar_info" />
        </receiver>

        <!-- N주 스케줄 위젯(읽기 전용) -->
        <receiver
            android:name=".ScheduleWidgetProvider"
            android:label="스케줄"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 휴대폰 시스템 다크/라이트 설정이 바뀌는 순간 위젯을 새로
                     그리기 위함(2026-07-18 추가) — 앱을 안 열고 위젯만 떠있는
                     상태에서 시스템 테마가 바뀌면 이전까지는 앱을 열기 전까지
                     위젯이 예전 밝기 그대로 남아있었음(색이 안 맞아 리스트가
                     제대로 안 보이는 신고 원인). -->
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_schedule_info" />
        </receiver>

        <!-- 스케줄 위젯에서 날짜 칸(월/일요일 넘기기 칸 제외)을 누르면 뜨는
             작은 화면 — 그 날짜 근무·할일 보기 + 새 할일 입력 -->
        <activity
            android:name=".DayQuickViewActivity"
            android:theme="@style/QuickAddDialogTheme"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:windowSoftInputMode="stateAlwaysVisible"
            android:exported="false" />

        <!-- 오늘 전체 관리 위젯(체크 가능) -->
        <receiver
            android:name=".TodayWidgetProvider"
            android:label="오늘 할일"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 휴대폰 시스템 다크/라이트 설정이 바뀌는 순간 위젯을 새로
                     그리기 위함(2026-07-18 추가) — 앱을 안 열고 위젯만 떠있는
                     상태에서 시스템 테마가 바뀌면 이전까지는 앱을 열기 전까지
                     위젯이 예전 밝기 그대로 남아있었음(색이 안 맞아 리스트가
                     제대로 안 보이는 신고 원인). -->
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_today_info" />
        </receiver>
        <service
            android:name=".TodayWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- 오늘 할일 위젯의 + 버튼에서 뜨는 입력창(할일추가 위젯과 같은
             모양·동작, 저장 위치만 오늘 날짜) -->
        <activity
            android:name=".TodayQuickAddActivity"
            android:theme="@style/QuickAddDialogTheme"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:windowSoftInputMode="stateAlwaysVisible"
            android:exported="false" />

        <!-- 미배치 위젯(읽기 전용) -->
        <receiver
            android:name=".InboxWidgetProvider"
            android:label="미배치 목록"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 휴대폰 시스템 다크/라이트 설정이 바뀌는 순간 위젯을 새로
                     그리기 위함(2026-07-18 추가) — 앱을 안 열고 위젯만 떠있는
                     상태에서 시스템 테마가 바뀌면 이전까지는 앱을 열기 전까지
                     위젯이 예전 밝기 그대로 남아있었음(색이 안 맞아 리스트가
                     제대로 안 보이는 신고 원인). -->
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_inbox_info" />
        </receiver>
        <service
            android:name=".InboxWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- 오늘 팀 근무 위젯(4x1, 읽기 전용, 2026-07-21 추가) -->
        <receiver
            android:name=".TeamTodayWidgetProvider"
            android:label="오늘 팀 근무"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 휴대폰 시스템 다크/라이트 설정이 바뀌는 순간 위젯을 새로
                     그리기 위함(다른 위젯들과 같은 이유). -->
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_team_today_info" />
        </receiver>

        <!-- 근무유형별 알람(2026-07-16, 진짜 기상 알람으로 재구현) — 이 시각에
             AlarmManager가 ShiftAlarmReceiver를 깨움 -->
        <receiver
            android:name=".ShiftAlarmReceiver"
            android:exported="false" />
        <!-- 알람이 울릴 때 화면 전체에 뜨는 화면(끄기/다시 울리기 버튼) -->
        <activity
            android:name=".ShiftAlarmActivity"
            android:theme="@style/ShiftAlarmTheme"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:exported="false" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 데이터 내보내기(saveBackupFile)에서 안드로이드 9 이하 기기일 때만 필요.
         안드로이드 10+에서는 MediaStore 방식이라 이 권한 자체가 필요 없음. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <!-- 근무 알람이 울릴 때 화면 전체를 강제로 띄우는 데 필요(전화 수신 화면과
         같은 원리) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- 오늘 탭 날씨(2026-07-19 추가) — @capacitor/geolocation이 필요로 함.
         GPS 하드웨어를 강제하는 <uses-feature>는 일부러 안 넣음(없어도 대략
         위치는 잡히고, 넣으면 GPS 없는 기기에는 설치 자체가 막히므로). -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
</manifest>
