<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 선택 화면 미리보기 전용 — 실제 데이터가 아니라 예시를 하드코딩(Java 안 건드림).
     widget_today.xml과 같은 구조지만, 목록(ListView) 대신 예시 줄 몇 개를 그냥 고정으로
     넣어둠(미리보기 렌더링에서는 RemoteViewsService가 안 돌아서 ListView가 비어 보이므로). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp"
            android:text="7월 14일 화요일" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#FF007AFF"
            android:background="#26007AFF"
            android:text="주간" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_off" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:text="🏥 병원 다녀오기" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_on" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/widget_text_secondary"
            android:textSize="14sp"
            android:text="🥋 아침 운동" />
    </LinearLayout>

    <!-- 2026-07-18: 실제 위젯이 "+" 텍스트에서 벡터 아이콘으로 바뀐 것과
         맞춤(이 미리보기는 정적 XML이라 자동 반영 안 되므로 직접 갱신). -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="14dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_widget_add" />

</LinearLayout>
