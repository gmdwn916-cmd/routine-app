<?xml version="1.0" encoding="utf-8"?>
<!-- 스케줄 위젯에서 날짜 칸(월/일요일 넘기기 칸 제외)을 누르면 뜨는 작은 화면
     (2026-07-16 신규) — QuickAddActivity와 같은 "다이얼로그처럼 뜨는 작은
     화면" 패턴을 그대로 씀. 그 날짜의 근무·할 일은 위젯이 이미 화면에 그리고
     있던 정보를 그대로 인텐트로 받아서 보여주기만 함(따로 다시 계산 안 함).
     체크·수정 기능은 없음(보기 전용) — 입력칸에 글자 쓰고 엔터 치면 그 날짜에
     바로 새 할 일이 추가됨(미배치 아님). -->
<!-- dqv_root: 이 카드 전체가 "앱 열기" 반응 영역(2026-07-19 추가) — 입력칸
     (dqv_input)만 자기 자신의 포커스/커서 배치로 터치를 직접 소비해서 이
     클릭이 안 불림, 나머지(날짜·근무·할 일 목록 글자, 여백)는 전부 이
     루트로 떨어져서 앱을 엶. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dqv_root"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:clickable="true"
    android:background="@drawable/quick_add_bg">

    <TextView
        android:id="@+id/dqv_date_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="17sp"
        android:textColor="@color/widget_text_primary" />

    <TextView
        android:id="@+id/dqv_shift_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textStyle="bold"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/dqv_todos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/widget_text_primary" />

    <!-- 2026-07-16: 이 화면 테마(QuickAddDialogTheme)가 라이트 고정이라 글자/
         힌트 색을 따로 안 주면 다크 모드에서 카드 배경은 어두워지는데 힌트
         글씨는 계속 까맣게 나와 안 보이는 문제가 있음 — activity_quick_add.xml과
         같은 이유, 같은 방식으로 고침. -->
    <EditText
        android:id="@+id/dqv_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="할 일을 입력하세요"
        android:textColor="@color/widget_text_primary"
        android:textColorHint="@color/widget_text_secondary"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:maxLength="50"
        android:textSize="16sp" />

</LinearLayout>
