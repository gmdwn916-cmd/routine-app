<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_today_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/today_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp" />
        <!-- 근무 표시칸 — 모서리를 둥글게 하려고 밑그림(ImageView, 둥근 사각형)
             위에 글자(TextView, 배경 없음)를 겹침. 자세한 이유는
             widget_badge_base_light.xml 주석 참고.
             **(2026-07-16 재수정)** 처음엔 FrameLayout(wrap_content) 안에
             ImageView를 match_parent로 넣었는데, 실제 기기에서 이 칸(글자
             포함) 전체가 아예 안 보이는 문제가 있었음 — wrap_content인
             부모 안에 match_parent 자식만 있으면(다른 형제가 없어서 부모의
             크기를 정해줄 기준이 없음) 크기가 0으로 무너지는 것으로 보임.
             RelativeLayout으로 바꿔서, ImageView가 "내 형제(today_shift)의
             테두리에 맞춰라"(alignLeft/Top/Right/Bottom)는 확실한 기준으로
             크기를 잡게 함 — 그림을 글자보다 먼저 적어서 글자 뒤에 깔림. -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/today_shift_bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignLeft="@id/today_shift"
                android:layout_alignTop="@id/today_shift"
                android:layout_alignRight="@id/today_shift"
                android:layout_alignBottom="@id/today_shift"
                android:scaleType="fitXY"
                android:src="@drawable/widget_badge_base_light" />
            <TextView
                android:id="@+id/today_shift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textStyle="bold"
                android:textSize="13sp" />
        </RelativeLayout>
    </LinearLayout>

    <ListView
        android:id="@+id/today_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/today_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:text="오늘 할 일이 없어요" />

    <!-- 맨 밑 두 줄 자리(목록 대신 큼지막한 + 버튼, 2026-07-16 추가, 미배치
         위젯과 같은 패턴) — 목록(today_list)은 위에서 이 자리만큼을 자동으로
         빼고 채워짐(같은 부모 LinearLayout 안의 형제라 weight=1인 목록·빈
         문구 쪽이 이 고정 높이를 뺀 나머지를 차지). -->
    <!-- 2026-07-18: 텍스트 "+" 글자 대신 위젯1(빠른 할일 추가)과 같은 벡터
         십자가 아이콘(ic_widget_add)으로 통일 — 위젯마다 "+"이 그림 아이콘
         (위젯1)/글자(이 위젯, 미배치 위젯)로 서로 다르게 생겨 보이던 것을
         정리함. -->
    <ImageView
        android:id="@+id/today_add_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="14dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_widget_add"
        android:contentDescription="할 일 추가" />

</LinearLayout>
