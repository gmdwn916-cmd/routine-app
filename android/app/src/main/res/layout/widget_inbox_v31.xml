<?xml version="1.0" encoding="utf-8"?>
<!-- widget_inbox.xml과 완전히 같지만(같은 뷰 id 재사용), 안드로이드 12(API 31)
     이상 기기에서만 쓰는 버전 — 오늘 위젯(widget_today_v31.xml)에서 고친 것과
     완전히 같은 문제를 여기서도 고침: inbox_list(ListView)가 weight=1로 남은
     공간을 전부 차지하면, 항목이 적을 때 목록 박스 안에 생기는 빈 여백은
     ListView 자신의 영역이라 눌러도 반응이 없었음. 고침: inbox_list는
     Java(InboxWidgetProvider.updateOne())가 setViewLayoutHeight로 실제 항목
     수만큼만 높이를 정확히 지정하고, 남는 진짜 여백은 별도 뷰
     inbox_list_filler(목록 소속이 아닌 평범한 뷰)가 차지해서 직접
     PendingIntent(앱 열기)를 걺 — 항상 확실히 반응함. API 31 미만 기기는
     setViewLayoutHeight를 못 써서 이 레이아웃 대신 예전 그대로인
     widget_inbox.xml을 계속 씀. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_inbox_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/inbox_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp"
            android:text="미배치 목록" />
        <TextView
            android:id="@+id/inbox_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- 높이는 XML 기본값(자리만 차지)이고, 실제 값은 매번 Java의
         setViewLayoutHeight()가 항목 개수에 맞춰 정확히 다시 지정함 — weight
         없음(inbox_list_filler 쪽이 남는 공간을 전부 가져가야 하므로). -->
    <ListView
        android:id="@+id/inbox_list"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/inbox_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:text="미배치 항목이 없어요" />

    <!-- inbox_list가 실제 항목 수만큼만 차지하고 남기는 진짜 빈 공간을 이
         뷰가 차지함 — 목록(ListView) 소속이 아닌 평범한 뷰라서 직접
         PendingIntent를 걸 수 있고, 그래서 이 빈 공간을 눌러도 항상 확실히
         앱이 열림(InboxWidgetProvider.updateOne() 참고). -->
    <TextView
        android:id="@+id/inbox_list_filler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/inbox_add_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="30sp"
        android:textColor="#007AFF"
        android:text="+" />

</LinearLayout>
