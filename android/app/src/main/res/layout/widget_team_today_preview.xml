<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 선택 화면 미리보기 전용(API 31+) — 실제 데이터가 아니라 예시를
     하드코딩(widget_team_today.xml과 같은 구조, Java 안 건드림). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background"
    android:paddingStart="10dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textColor="@color/widget_text_primary"
        android:textSize="16sp"
        android:text="7/21(화)" />

    <!-- 1팀 = 내 팀 예시 — 오늘 표시와 같은 옅은 파란 배경 + 테두리로 강조 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_myteam_highlight">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="#007AFF"
            android:textSize="13sp"
            android:text="1팀" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#007AFF"
            android:text="야간" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:text="2팀" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#34A853"
            android:text="비번" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:text="3팀" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/widget_text_secondary"
            android:text="휴무" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:text="4팀" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:gravity="center"
            android:maxLines="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="#0A84FF"
            android:text="주간" />
    </LinearLayout>

</LinearLayout>
