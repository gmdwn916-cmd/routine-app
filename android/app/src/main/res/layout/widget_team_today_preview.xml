<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 선택 화면 미리보기 전용(API 31+) — 실제 데이터가 아니라 예시를
     하드코딩(widget_team_today.xml과 같은 구조, Java 안 건드림). 세로 위치
     (스페이서 weight 3:1), 근무 배지 좌우 여백(6dp), 타이포그래피 위계
     (날짜/팀 이름은 sans-serif-medium, 근무 이름만 bold)도 실제 위젯과
     항상 같이 맞출 것. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:paddingStart="14dp"
    android:paddingEnd="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/widget_text_primary"
            android:textSize="15sp"
            android:text="7/21(화)" />

        <!-- 1팀 = 내 팀 예시 — 오늘 표시와 같은 옅은 파란 배경 + 테두리로 강조 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/widget_myteam_highlight">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="1"
                android:fontFamily="sans-serif-medium"
                android:textColor="#007AFF"
                android:textSize="11sp"
                android:text="1팀" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:maxLines="1"
                android:textStyle="bold"
                android:textSize="17sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="#007AFF"
                android:text="야간" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="1"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:text="2팀" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:maxLines="1"
                android:textStyle="bold"
                android:textSize="17sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="#34A853"
                android:text="비번" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="1"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:text="3팀" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:maxLines="1"
                android:textStyle="bold"
                android:textSize="17sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/widget_text_secondary"
                android:text="휴무" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="1"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:text="4팀" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="3dp"
                android:gravity="center"
                android:maxLines="1"
                android:textStyle="bold"
                android:textSize="17sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="#0A84FF"
                android:text="주간" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
