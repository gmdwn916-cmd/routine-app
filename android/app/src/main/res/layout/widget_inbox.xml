<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_inbox_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/inbox_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp"
            android:text="미배치 목록" />
        <TextView
            android:id="@+id/inbox_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ListView
        android:id="@+id/inbox_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />

    <TextView
        android:id="@+id/inbox_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:text="미배치 항목이 없어요" />

    <!-- 맨 밑 두 줄 자리(목록 대신 큼지막한 + 버튼, 2026-07-16 추가) — 목록
         (inbox_list)은 위에서 이 자리만큼을 자동으로 빼고 채워짐(둘 다 같은
         부모 LinearLayout 안의 형제라, 이 뷰가 차지하는 고정 높이를 뺀
         나머지만 weight=1인 목록·빈 문구 쪽으로 감). -->
    <!-- 2026-07-18: 텍스트 "+" 글자 대신 위젯1(빠른 할일 추가)과 같은 벡터
         십자가 아이콘(ic_widget_add)으로 통일. -->
    <ImageView
        android:id="@+id/inbox_add_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="14dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_widget_add"
        android:contentDescription="미배치 항목 추가" />

</LinearLayout>
