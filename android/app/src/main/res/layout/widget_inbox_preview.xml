<?xml version="1.0" encoding="utf-8"?>
<!-- 위젯 선택 화면 미리보기 전용 — 실제 데이터가 아니라 예시를 하드코딩(Java 안
     건드림). widget_inbox.xml과 같은 구조지만, 목록(ListView) 대신 예시 줄
     몇 개를 그냥 고정으로 넣어둠(미리보기 렌더링에서는 RemoteViewsService가
     안 돌아서 ListView가 비어 보이므로 — 위젯 4 미리보기와 같은 이유). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp"
            android:text="미배치 목록" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp"
            android:text="3개" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/widget_text_secondary"
            android:textSize="14sp"
            android:text="•" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:text="타이어 교체하기" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/widget_text_secondary"
            android:textSize="14sp"
            android:text="•" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:text="책 반납하기" />
    </LinearLayout>

    <!-- 2026-07-18: 실제 위젯과 맞춤(위 today_preview.xml과 같은 이유). -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="14dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_widget_add" />

</LinearLayout>
